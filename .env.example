GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.2
GEMINI_MAX_OUTPUT_TOKENS=1024

DIALOGFLOW_AGENT_ID=your-dialogflow-cx-agent-id
DIALOGFLOW_LOCATION=global

GCS_BUCKET_NAME=telecom-support-knowledge-base
CHROMA_PERSIST_DIR=./chroma_db

LOG_LEVEL=INFO
APP_ENV=production
APP_PORT=8080

SESSION_TTL_SECONDS=1800
MAX_HISTORY_TURNS=10

DATABASE_URL=postgresql://telenova:telenova_dev@localhost:5432/telenova
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_COMMAND_TIMEOUT_SECONDS=10

# Production (AlloyDB) example — uncomment and configure when deploying:
# DATABASE_URL=postgresql://telenova:CHANGE_ME@/telenova?host=/cloudsql/PROJECT:REGION:alloydb-cluster
